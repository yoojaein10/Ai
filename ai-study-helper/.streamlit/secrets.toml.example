# 구글 로그인 설정 — 이 파일을 secrets.toml로 복사하고 값을 채우면 로그인이 활성화된다.
# secrets.toml이 없으면 앱은 로그인 없이 동작한다 (로컬 개인 사용 모드).
#
# 발급: Google Cloud Console → API 및 서비스 → 사용자 인증 정보
#       → OAuth 클라이언트 ID(웹 애플리케이션) 생성
#       승인된 리디렉션 URI에 아래 redirect_uri를 그대로 등록할 것.

[auth]
# redirect_uri는 "사용자가 접속하는 주소" 기준이다:
# - 이 PC에서만 쓸 때: http://localhost:8501/oauth2callback
# - 외부 공유(터널/배포) 시: https://공개도메인/oauth2callback 으로 바꾸고,
#   같은 주소를 Google Console 리디렉션 URI에도 등록해야 외부 로그인이 동작한다.
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "아무-긴-무작위-문자열로-교체"  # 세션 쿠키 서명용
client_id = "xxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[access]
# 입장 허용 구글 계정. 비워두면([]) 구글 로그인만 되면 누구나 입장.
allowed_emails = ["t_5000@naver.com"]
